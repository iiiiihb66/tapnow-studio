    "playwright-core": "^1.58.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vite-plugin-singlefile": "^2.0.1",
    "ws": "^8.20.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^1.5.0",
    "yjs": "^13.6.30"
