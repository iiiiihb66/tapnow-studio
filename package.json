    "i18next": "^23.12.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "marked": "^12.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.1.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
